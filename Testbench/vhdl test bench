library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity and_gate_tb is
-- Empty entity for testbench
end and_gate_tb;

architecture sim of and_gate_tb is

    -- 1. Component declaration matching your DUT exactly
    component and_gate is
        port (
            A  : in  std_logic;
            B  : in  std_logic;
            y1 : out std_logic;
            y2 : out std_logic;
            y3 : out std_logic;
            y4 : out std_logic
        );
    end component and_gate;

    -- 2. Testbench internal signals
    signal r_A  : std_logic := '0';
    signal r_B  : std_logic := '0';
    signal w_y1 : std_logic;
    signal w_y2 : std_logic;
    signal w_y3 : std_logic;
    signal w_y4 : std_logic;

begin

    -- 3. Instantiate the Unit Under Test (UUT)
    UUT: and_gate
        port map (
            A  => r_A,
            B  => r_B,
            y1 => w_y1,
            y2 => w_y2,
            y3 => w_y3,
            y4 => w_y4
        );

    -- 4. Stimulus generation and auto-verification process
    process
    begin
        -- Test Case 1: A = 0, B = 0
        -- Expected: y1(AND)=0, y2(OR)=0, y3(NOT A)=1, y4(XOR)=0
        r_A <= '0'; r_B <= '0';
        wait for 10 ns;
        assert (w_y1 = '0' and w_y2 = '0' and w_y3 = '1' and w_y4 = '0')
            report "Error at State 00" severity error;

        -- Test Case 2: A = 0, B = 1
        -- Expected: y1(AND)=0, y2(OR)=1, y3(NOT A)=1, y4(XOR)=1
        r_A <= '0'; r_B <= '1';
        wait for 10 ns;
        assert (w_y1 = '0' and w_y2 = '1' and w_y3 = '1' and w_y4 = '1')
            report "Error at State 01" severity error;

        -- Test Case 3: A = 1, B = 0
        -- Expected: y1(AND)=0, y2(OR)=1, y3(NOT A)=0, y4(XOR)=1
        r_A <= '1'; r_B <= '0';
        wait for 10 ns;
        assert (w_y1 = '0' and w_y2 = '1' and w_y3 = '0' and w_y4 = '1')
            report "Error at State 10" severity error;

        -- Test Case 4: A = 1, B = 1
        -- Expected: y1(AND)=1, y2(OR)=1, y3(NOT A)=0, y4(XOR)=0
        r_A <= '1'; r_B <= '1';
        wait for 10 ns;
        assert (w_y1 = '1' and w_y2 = '1' and w_y3 = '0' and w_y4 = '0')
            report "Error at State 11" severity error;

        -- End of Simulation
        report "All test cases passed successfully!";
        wait;
    end process;

end sim;
